# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=FeoSync
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_VERSION=1.0.0
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,https://app.feosync.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://feosync:feosync_pass@localhost:5432/feosync_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# ── Meta / Facebook ───────────────────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_GRAPH_API_VERSION=v19.0
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
META_OAUTH_REDIRECT_URI=https://app.feosync.com/api/v1/facebook-pages/callback

# ── AI – Google Gemini ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ── Storage – Cloudflare R2 ───────────────────────────────────────────────────
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=feosync-assets
R2_PUBLIC_URL=https://assets.feosync.com

# ── Email – Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@feosync.com
EMAIL_FROM_NAME=FeoSync

# ── Encryption (for FB tokens stored in DB) ──────────────────────────────────
ENCRYPTION_KEY=CHANGE_THIS_32_BYTE_BASE64_KEY_IN_PRODUCTION

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
